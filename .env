# ============================================
# DRISHTI - Configuration
# ============================================

# Raspberry Pi Connection
PI_IP=10.42.0.50
PI_USER=abhiroop
PI_PASSWORD=12345678
PI_SSH_PORT=22

# Video Stream
STREAM_PORT=8080
STREAM_WIDTH=800
STREAM_HEIGHT=600
STREAM_FPS=30

# YOLO Settings
YOLO_MODEL=yolov8n.pt
YOLO_CONFIDENCE=0.5
YOLO_MAX_PEOPLE=10

# BLIP Settings  
BLIP_MODEL=Salesforce/blip-image-captioning-large
BLIP_DEFAULT_MODE=default

# TTS Settings
TTS_ENGINE=gtts
TTS_LANGUAGE=en
TTS_SLOW=false

# GPIO Pins (on Pi)
BTN_CAPTURE=17
BTN_MODE=27
BTN_YOLO_ALERT=22
LED_RED=5
LED_GREEN=6
LED_BLUE=13

# Paths
AUDIO_OUTPUT_DIR=./audio_output
CAPTURE_DIR=./captures
LOG_DIR=./logs
