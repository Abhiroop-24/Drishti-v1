# ─────────────────────────────────────────────────────────────
#  DRISHTI – Environment Configuration
#  Copy this file to `.env` and adjust values as needed.
#  All values shown below are the application defaults.
# ─────────────────────────────────────────────────────────────

# ── Raspberry Pi ──────────────────────────────────────────────
PI_IP=10.42.0.50
PI_USER=abhiroop
PI_PASSWORD=12345678
PI_SSH_PORT=22

# ── Video Stream (must match pi_scripts/start_camera.sh) ──────
STREAM_PORT=8080
STREAM_WIDTH=800
STREAM_HEIGHT=600
STREAM_FPS=30

# ── YOLOv8 ───────────────────────────────────────────────────
YOLO_MODEL=yolov8n.pt          # yolov8n (fastest) | yolov8s | yolov8m
YOLO_CONFIDENCE=0.5            # Detection confidence threshold (0-1)
YOLO_MAX_PEOPLE=10             # Maximum people tracked simultaneously
YOLO_ALERT_COOLDOWN=5.0        # Seconds between spoken proximity alerts
YOLO_EVERY_N_FRAMES=2          # Run YOLO every N frames (1=every, 2=alternate)
# Camera focal length for distance estimation at 800x600.
# Re-calibrate: stand exactly 2 m away, measure person height in pixels,
# then set FOCAL_LENGTH = (2.0 * px_height) / 1.7
YOLO_FOCAL_LENGTH=615.0

# ── BLIP Image Captioning ─────────────────────────────────────
# blip-image-captioning-large : good quality, ~1.5 GB download
# Salesforce/blip2-opt-2.7b   : better quality, needs ~6 GB VRAM + bitsandbytes
BLIP_MODEL=Salesforce/blip-image-captioning-large
BLIP_DEFAULT_MODE=default      # default | short | story

# ── Text-to-Speech ────────────────────────────────────────────
TTS_ENGINE=gtts                # gtts (online) | pyttsx3 (offline)
TTS_LANGUAGE=en
TTS_SLOW=false

# ── GPIO Pin Assignments (Raspberry Pi) ─────────────────────
BTN_CAPTURE=17                 # B1 – Capture & Describe
BTN_MODE=27                    # B2 – Cycle BLIP mode
BTN_YOLO_ALERT=22              # B3 – Toggle YOLO alerts
LED_RED=5
LED_GREEN=6
LED_BLUE=13

# ── Paths ────────────────────────────────────────────────────
AUDIO_OUTPUT_DIR=./audio_output
CAPTURE_DIR=./captures
LOG_DIR=./logs
